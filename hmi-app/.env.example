# =============================================================================
# Node-RED HMI Integration
# =============================================================================
# Base URL for the Node-RED overview endpoint.
# Set this to enable real-variable binding from Node-RED.
# Must be reachable from the browser (use proxy/gateway for self-signed certs).
# Leave empty to disable Node-RED integration (widgets fall back to simulated mode).
#
# Example: https://192.168.50.250:51880
VITE_NODE_RED_BASE_URL=
